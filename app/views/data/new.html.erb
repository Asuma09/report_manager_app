<div class="max-w-2xl mx-auto p-8">
  <div class="mb-8">
    <%= link_to "← 戻る", tasks_path, class: "text-blue-500 hover:text-blue-700 text-sm font-medium" %>
    <h1 class="text-3xl font-bold text-gray-800 mt-2">
      「<span class="text-blue-600"><%= @task.title %></span>」に資料を追加
    </h1>
  </div>

  <div class="bg-white shadow-lg rounded-2xl p-8 border border-gray-100">
    <%= form_with model: [@task, @datum] do |f| %>
      
      <%# 資料種別の選択 %>
      <div class="mb-6">
        <%= f.label :data_type, "資料の種類", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.select :data_type, 
            [["🌐 URL（Webサイト）", "url"], ["🖼️ 画像", "image"], ["📝 Wordファイル", "word"]], 
            {}, 
            { class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none transition appearance-none" } %>
      </div>

      <%# URL入力欄 %>
      <div class="mb-6">
        <%= f.label :content, "URL（Webサイトの場合）", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :content, placeholder: "https://example.com", 
            class: "w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none transition" %>
      </div>

      <%# ファイル選択欄 %>
      <div class="mb-8">
        <%= f.label :file, "ファイル（画像・Wordの場合）", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-blue-400 transition">
          <div class="space-y-1 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <div class="flex text-sm text-gray-600">
              <%= f.file_field :file, class: "cursor-pointer font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none" %>
            </div>
            <p class="text-xs text-gray-500">PNG, JPG, DOCX up to 10MB</p>
          </div>
        </div>
      </div>

      <div class="flex justify-end">
        <%= f.submit "資料を登録する", 
            class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-xl cursor-pointer transition shadow-md hover:shadow-lg w-full md:w-auto" %>
      </div>
    <% end %>
  </div>
</div>