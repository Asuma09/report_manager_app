<h1>レポート一覧</h1>

<%= link_to "新しいレポートを追加", new_task_path %>

<hr>

<ul>
  <% @tasks.each do |task| %>
    <li style="margin-bottom: 20px;">
      <strong><%= task.title %></strong> 
      <%= link_to "[編集]", edit_task_path(task) %>
      <%= link_to "[資料追加]", new_task_datum_path(task) %>
      <%= link_to "[削除]", task_path(task), 
                  data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, 
                  style: "color: red;" %>
      <ul>
        <% task.data_list.each do |datum| %>
          <li>
            <% opener = datum.opener %>
            <%= opener.icon %> 
            <%= link_to opener.link_text, opener.target_path, target: "_blank" %>
          </li>
        <% end %>
      </ul>
    </li>
  <% end %>
</ul>